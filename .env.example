# paraket_Admin
# Same Postgres as main ParakeetAI app
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/parakeetai"

# Admin login (required). Run once: node scripts/hash-password.mjs "YourLongPassword" (12+ chars)
# Paste the output: salt:hex
ADMIN_PASSWORD_HASH=""

# JWT signing secret for httpOnly cookie — min 32 characters (e.g. openssl rand -base64 48)
ADMIN_JWT_SECRET=""

# Whispr main app (required for Access Requests → Approve / Reject)
WHISPR_APP_URL="http://localhost:3000"
# Must match INTERNAL_ADMIN_SHARED_SECRET in the Whispr .env (header x-whispr-internal-secret)
INTERNAL_ADMIN_SHARED_SECRET=""
