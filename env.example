# Same Postgres as main Whispr app
DATABASE_URL="postgresql://whispr:whispr_dev@localhost:5432/whispr"

# ── Admin password ────────────────────────────────────────────────────────────
# RECOMMENDED: Generate a scrypt hash and set ADMIN_PASSWORD_HASH.
# Run this in Node to generate one:
#
#   node -e "
#     const {scrypt,randomBytes}=require('crypto');
#     const {promisify}=require('util');
#     const s=randomBytes(16).toString('hex');
#     promisify(scrypt)('YourPasswordHere',s,64)
#       .then(k=>console.log(s+':'+k.toString('hex')));
#   "
#
# Then set:
ADMIN_PASSWORD_HASH=""

# LEGACY (plain text) — only used when ADMIN_PASSWORD_HASH is not set.
# Still works but logs a deprecation warning in production.
ADMIN_PASSWORD="change-me-in-production"

# JWT signing secret for httpOnly cookie — min 32 characters
# Generate: openssl rand -base64 48
ADMIN_JWT_SECRET="replace-with-48-char-random-string"

# Whispr main app URL (required for sending approval emails)
WHISPR_APP_URL="http://localhost:3000"

# Shared secret with Whispr — must match WHISPR_ADMIN_SERVICE_SECRET in the Whispr .env
WHISPR_ADMIN_SERVICE_SECRET=""

# Optional: shown in audit log when using the service secret
WHISPR_ADMIN_AUDIT_EMAIL=""
