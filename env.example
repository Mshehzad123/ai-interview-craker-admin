# Same Postgres as main ParakeetAI app
DATABASE_URL="postgresql://postgres:12345@localhost:5433/parakeetai"

# Admin login (use a long random password in production)
ADMIN_PASSWORD="123456"

# JWT signing secret for httpOnly cookie — min 32 characters (e.g. openssl rand -base64 48)
ADMIN_JWT_SECRET="Adminadmin"

# Whispr main app (required for Access Requests → Approve / Reject — emails send from Whispr)
# Use the same base URL as NEXTAUTH_URL / NEXT_PUBLIC_APP_URL on Whispr (e.g. http://localhost:3000)
WHISPR_APP_URL="http://localhost:3000"
# Shared secret with Whispr — must match WHISPR_ADMIN_SERVICE_SECRET in the Whispr .env (long random string)
WHISPR_ADMIN_SERVICE_SECRET="SevXu7L/Sn1lUKYTwHYUTswPt/JeXNGEYvE1tHNSE6k="
